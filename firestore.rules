rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Signatures collection - users can only access their own signatures
    match /signatures/{signatureId} {
      // Allow read (get and list) if authenticated
      // For list queries, Firestore validates at query time that userId == auth.uid
      allow read: if request.auth != null;
      
      // Allow create if the user is authenticated and they're setting their own userId
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      
      // Allow update if the user is authenticated and the signature belongs to them
      allow update: if request.auth != null && 
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;
      
      // Allow delete if the user is authenticated and the signature belongs to them
      allow delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
  }
}
